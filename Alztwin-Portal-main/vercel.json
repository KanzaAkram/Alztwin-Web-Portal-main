{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/stage",
      "destination": "https://alztwin-prediction-api.azurewebsites.net/predict"
    },
    {
      "source": "/api/progression",
      "destination": "https://alztwin-trajectory-yusra-sea.azurewebsites.net/predict"
    },
    {
      "source": "/api/cognitive",
      "destination": "https://alztwin-voice-api.azurewebsites.net/predict"
    },
    {
      "source": "/api/brain/:path*",
      "destination": "https://alztwin-brain-api.azurewebsites.net/:path*"
    },
    {
      "source": "/api/rag/:path*",
      "destination": "https://func-alztwin-proto.azurewebsites.net/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
